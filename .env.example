# Node Environment
NODE_ENV=development

# Backend Integration
BACKEND_URL=http://localhost:8000
INTERNAL_API_KEY=your-internal-api-key-here

# Sarvam AI — language identification + transliteration (22 Indic languages)
# Get your key at https://dashboard.sarvam.ai
SARVAM_API_KEY=your-sarvam-api-key-here

# Anthropic — Claude Haiku 3.5 powers the intent + output-language reasoner
# (low-cost, high-reasoning sub-agent). Get key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI — gpt-4o-mini fallback reasoner (used if Anthropic is unreachable).
# Get key at https://platform.openai.com
OPENAI_API_KEY=your-openai-api-key-here

# Storage
REDIS_URL=redis://localhost:6379
WWEBJS_SESSION_PATH=./.wwebjs_auth

# WhatsApp Configuration
WWEBJS_HEADLESS=true
GROUP_FEATURES_ENABLED=true
PRIVACY_MODE=false

# Rate Limiting
MESSAGES_PER_MINUTE=20
MAX_QUEUE_SIZE=1000

# Monitoring
METRICS_ENABLED=true
LOG_LEVEL=info

# Health Check
HEALTH_CHECK_PORT=3000
